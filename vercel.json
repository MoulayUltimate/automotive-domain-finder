{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "/api/index.py" },
    { "src": "/login",     "dest": "/login.html"   },
    { "src": "/admin",     "dest": "/admin.html"   },
    { "src": "/keyword",   "dest": "/keyword.html" },
    { "src": "/keywords",  "dest": "/keyword.html" },
    { "src": "/(.+\\.html)","dest": "/$1"          },
    { "src": "/(.*)",      "dest": "/index.html"   }
  ]
}
